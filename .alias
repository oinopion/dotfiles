# Universal alias file - should work with bash, zsh and fish
alias cat="bat"

alias ls="eza"
alias l="eza -1"
alias ll="eza -lh"
alias la="eza -lha"
alias t="eza -TL2"

alias j="just"
alias d="docker"
alias dc="docker compose"
alias tf="terraform"
alias tg="terragrunt"
alias k="clear"

alias ur="uv run"
alias urt="uv run task"

alias dotfiles-edit="code ~/.dotfiles"
alias dotfiles-update="bash -x -c 'cd ~/.dotfiles && git pull && ./install.sh'"
